<Window x:Class="OEEDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:views="clr-namespace:OEEDashboard.Views"
        mc:Ignorable="d"
        Title="OEE Dashboard"
        Height="900"
        Width="1400"
        MinHeight="720"
        MinWidth="1100"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="OEE Dashboard"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}" />
                <TextBlock Text="{Binding DataSourceLabel}"
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,4,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ComboBox ItemsSource="{Binding Lines}"
                          SelectedItem="{Binding SelectedLine}"
                          DisplayMemberPath="Name"
                          Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding DateRangeOptions}"
                          SelectedItem="{Binding SelectedDateRange}"
                          DisplayMemberPath="Label"
                          Margin="0,0,8,0" />
                <Button Content="새로고침"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding RefreshCommand}" />
            </StackPanel>
        </Grid>

        <!-- KPI Cards -->
        <UniformGrid Grid.Row="1"
                     Columns="4"
                     Margin="0,0,0,16">
            <views:KpiCardView DataContext="{Binding OeeKpi}" Margin="0,0,8,0" />
            <views:KpiCardView DataContext="{Binding AvailabilityKpi}" Margin="0,0,8,0" />
            <views:KpiCardView DataContext="{Binding PerformanceKpi}" Margin="0,0,8,0" />
            <views:KpiCardView DataContext="{Binding QualityKpi}" />
        </UniformGrid>

        <!-- Charts row 1 -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,8,0">
                <Grid>
                    <TextBlock Text="설비별 OEE"
                               Style="{StaticResource SectionTitleStyle}" />
                    <lvc:CartesianChart Series="{Binding EquipmentOeeSeries}"
                                        XAxes="{Binding EquipmentOeeXAxes}"
                                        YAxes="{Binding EquipmentOeeYAxes}"
                                        Margin="0,28,0,0"
                                        Height="260" />
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <TextBlock Text="OEE 추이"
                               Style="{StaticResource SectionTitleStyle}" />
                    <lvc:CartesianChart Series="{Binding TrendSeries}"
                                        XAxes="{Binding TrendXAxes}"
                                        YAxes="{Binding TrendYAxes}"
                                        Margin="0,28,0,0"
                                        Height="260"
                                        LegendPosition="Top" />
                </Grid>
            </Border>
        </Grid>

        <!-- Charts row 2 + Alarms -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,8,0">
                <Grid>
                    <TextBlock Text="다운타임 원인 (Pareto)"
                               Style="{StaticResource SectionTitleStyle}" />
                    <lvc:CartesianChart Series="{Binding DowntimeSeries}"
                                        XAxes="{Binding DowntimeXAxes}"
                                        YAxes="{Binding DowntimeYAxes}"
                                        Margin="0,28,0,0" />
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="활성 알람"
                               Style="{StaticResource SectionTitleStyle}" />

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Alarms}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderBrushColor}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,0,0,10"
                                        Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{Binding Severity, Converter={StaticResource AlarmSeverityToBrushConverter}}"
                                                CornerRadius="2"
                                                Margin="0,2,10,2" />

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding EquipmentName}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Message}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,2,0,0" />
                                            <TextBlock Text="{Binding OccurredAt, StringFormat='{}{0:HH:mm:ss}'}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       FontSize="11"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource MutedTextStyle}"
                           VerticalAlignment="Center" />
                <TextBlock Text=" · "
                           Style="{StaticResource MutedTextStyle}"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock Text="로딩 중..."
                           Style="{StaticResource MutedTextStyle}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>

            <TextBlock Grid.Column="1"
                       Text="{Binding LastUpdatedText}"
                       Style="{StaticResource MutedTextStyle}"
                       VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Window>
